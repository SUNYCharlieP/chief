# ---- Convex ----
# Get these by running: npx convex dev
# Convex will create a project and auto-populate your .env.local.
CONVEX_DEPLOYMENT=
VITE_CONVEX_URL=
# Optional server-only override. Leave commented for local Vite dev; the server
# falls back to VITE_CONVEX_URL, and Convex CLI warns if both active URL vars exist.
# CONVEX_URL=

# ---- iMessage transport (local, no third-party API) ----
# Chief polls ~/Library/Messages/chat.db for new messages in the chat with
# CHIEF_CONTACT and replies via AppleScript / JXA. Full Disk Access for your
# terminal is required (System Settings → Privacy & Security → Full Disk
# Access). For v1 we use a "self-thread" — set CHIEF_CONTACT to your own
# phone number (E.164, e.g. +15551234567); Chief will iMessage you, and
# your replies from any signed-in device get picked up by the poller.
CHIEF_CONTACT=
CHIEF_POLL_INTERVAL_MS=5000

# ---- Hacker News RSS source (Phase 7) ----
# Override the feed URL if you want a different HN slice (e.g. /newest.rss,
# /best.rss, or a topic-specific firehose). Default: front-page.
# HN_RSS_URL=https://news.ycombinator.com/rss

# ---- YouTube passive stage ----
# Topic-search needs a free Google Cloud API key (simple key, public data).
# Must-watch channels work via RSS without it.
# YOUTUBE_API_KEY=
# Comma-separated seed lists (used only to seed the Convex source tables on
# first boot; edit live over iMessage via youtube_config afterward).
# YOUTUBE_TOPICS=agentic coding,claude code,local-first apps
# YOUTUBE_CHANNELS=https://www.youtube.com/@ChrisRaroque
# Tunable bars (defaults shown). Bias hard toward silence.
# YOUTUBE_PROACTIVE_THRESHOLD=85
# YOUTUBE_MUSTWATCH_PROACTIVE_THRESHOLD=85
# YOUTUBE_PULL_THRESHOLD=58
# YOUTUBE_HOLD_DAYS=3
# YOUTUBE_TOPIC_CAP=10
# YOUTUBE_DISCOVER_LOOKBACK_DAYS=2
# YOUTUBE_DISCOVER_CRON=0 4 * * *

# ---- Linear observation source ----
# Linear uses the managed Composio connection (OAuth, connect once in the
# Connections panel). No key needed when connected. Optional GraphQL fallback
# only if you prefer a personal key over Composio (not built unless needed):
# LINEAR_API_KEY=
# LINEAR_OBSERVE_CRON=0 3 * * *
# LINEAR_FIRST_LOOKBACK_DAYS=14

# ---- Observation log (Phase 9: git observer) ----
# Absolute path to the directory containing the git repos Chief should
# observe. The git observer walks each repo and records new commits as
# observations (queryable via the recall_activity tool). When Chief runs in a
# separate macOS user from your projects, set this to the projects' absolute
# path, e.g. /Users/charlie/Developer. Defaults to ~/Developer (only correct
# when Chief and the projects share a user).
# CHIEF_OBSERVE_ROOT=/Users/charlie/Developer
# Cron for the observer (default every 6 hours). Timezone follows the server.
# CHIEF_OBSERVE_CRON=0 */6 * * *
# git log --since window. Generous overlap is fine; commits dedup by SHA.
# CHIEF_OBSERVE_LOOKBACK=2 days ago

# ---- Job-intel watcher (Adzuna source) ----
# Free API credentials from https://developer.adzuna.com (register an app).
# app_id is ~8 chars, app_key ~32 chars. Used by scripts/prove-jobs.ts (Phase 1)
# and the job observer (Phase 2). Without these the watcher is a no-op.
# ADZUNA_APP_ID=
# ADZUNA_APP_KEY=
# Optional knobs (defaults shown): salary floor, listings scored per run, score
# model, max listing age in days, Adzuna country code.
# CHIEF_JOB_SALARY_FLOOR=80000
# CHIEF_JOB_CAP=15
# CHIEF_JOB_SCORE_MODEL=claude-opus-4-8
# CHIEF_JOB_MAX_DAYS_OLD=30
# ADZUNA_COUNTRY=us
# The candidate profile the scorer judges against (biographical; keep it out of
# git and set it here in .env.local). Without it, a generic placeholder is used
# with weaker construction-vs-generic discrimination. One line.
# CHIEF_JOB_PROFILE=Former <trade> contractor and business owner, ~N years field + ops experience, pivoting to construction PM; field/ownership experience is the selling point.

# ---- Brain files (canonical user context) ----
# Path to a directory containing Agents.md, Context.md, Memory.md, Skills.md.
# Loaded at every interaction-agent turn and watched for changes via chokidar.
# Defaults to ~/Library/Mobile Documents/com~apple~CloudDocs/Brain (iCloud Drive
# location, the macOS canonical spot for cross-device editing).
# CHIEF_BRAIN_DIR=

# ---- Agent runtime ----
# claude = Claude Agent SDK / Claude Code path. codex = local `codex app-server`
# path using the ChatGPT/Codex account from `codex login`.
BOOP_RUNTIME=claude

# ---- Claude model ----
# Uses your Claude Code subscription automatically — no separate API key needed.
# Override with ANTHROPIC_API_KEY if you want to bypass the subscription.
# This is the *fallback*; runtime overrides set via the iMessage set_model tool
# (stored in the Convex `settings` table) take precedence.
BOOP_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=

# ---- Codex model ----
# Used when BOOP_RUNTIME=codex or the runtime setting is switched to Codex.
# Requires `codex login` on the host. BOOP_CODEX_AUTH_HOME can point at another
# Codex home containing auth.json if needed.
BOOP_CODEX_MODEL=gpt-5.5
BOOP_CODEX_REASONING_EFFORT=medium
# BOOP_CODEX_AUTH_HOME=

# ---- Local browser use ----
# Patchright-backed Chrome profile for login-required services, visual browser
# workflows, and bot-wall-sensitive sites. Debug UI settings stored in Convex
# take precedence over these fallbacks. Off by default; enable in Settings
# before agents can see or use the local browser integration.
# BOOP_BROWSER_ENABLED=false
# BOOP_BROWSER_PROFILE_DIR=~/.boop/browser-profile
# BOOP_BROWSER_SHOW_UI=true
# BOOP_BROWSER_LOGIN_HANDOFF=false
# BOOP_BROWSER_START_URL=
# BOOP_BROWSER_CHANNEL=chrome
# BOOP_BROWSER_EXECUTABLE_PATH=
# BOOP_BROWSER_EXTRA_ARGS=

# ---- Proactive email surfacing ----
# Phone number that receives proactive iMessage notices when the Gmail watcher
# decides an inbound email is worth surfacing. Single-user assumption for v1.
# Without this, the webhook still registers but notices are dropped.
BOOP_USER_PHONE=
# Set to "false" to skip auto-registering the Composio webhook URL on each
# `npm run dev`. Use when you want to manage the subscription manually.
# COMPOSIO_AUTO_WEBHOOK=

# ---- Upgrade notifications ----
# On `npm run dev`, Boop checks your `upstream` remote for new commits and
# prints a banner with the commit count + a reminder to run `/upgrade-boop`.
# Set to `false` to silence the check entirely.
# BOOP_UPSTREAM_CHECK=true

# ---- Embeddings (optional — paid providers for memory recall) ----
# Tried in order: Voyage → OpenAI → local Transformers.js (Xenova/bge-large-
# en-v1.5, 1024-dim, free, ~440MB one-time download). Leave both blank to
# use the local fallback. All three produce 1024-dim vectors so the Convex
# index stays compatible regardless of which is active.
# VOYAGE_API_KEY=
# OPENAI_API_KEY=

# ---- Server ----
PORT=3456

# Public URL for your server.
# - Leave as http://localhost:3456 if you're using free ngrok (URL changes each restart).
# - Set to your stable public URL (e.g. https://boop.mydomain.com) if you use
#   Cloudflare Tunnel, a Caddy server, or any other tunnel with a fixed URL —
#   `npm run dev` will then skip ngrok.
PUBLIC_URL=http://localhost:3456

# Optional: ngrok RESERVED domain (paid plan). Example: "boop.ngrok.app".
# When set, `npm run dev` launches ngrok with --domain=$NGROK_DOMAIN so your
# public URL stays the same across restarts.
# NGROK_DOMAIN=

# ---- Composio (1000+ integrations, zero-code) ----
# Get an API key at https://app.composio.dev/developers.
# Once set, connect toolkits (Gmail, Slack, GitHub, Linear, …) from the
# Debug UI's Connections tab. Each connected toolkit becomes available to
# the agent via spawn_agent(integrations: [...]).
COMPOSIO_API_KEY=

# Optional: stable user id Composio keys connections under. Defaults to
# "boop-default". Override only if you already manage Composio sessions
# elsewhere and want Boop to reuse that user.
# COMPOSIO_USER_ID=

# --- Image retention (optional) ---
# Days to keep iMessage-received image bytes. Images referenced by a
# memory record are kept indefinitely regardless of this setting.
# Set to 0 to disable cleanup (debug only).
BOOP_IMAGE_RETENTION_DAYS=3
BOOP_IMAGE_CLEANUP_INTERVAL_MS=43200000

# Single-user bearer auth (defense-in-depth behind Tailscale).
# Generate: openssl rand -hex 32 — store the same value in the app.
CHIEF_AUTH_TOKEN=
# accept = soft launch (log only) · require = reject without a valid token · off = disabled
CHIEF_AUTH_MODE=accept
